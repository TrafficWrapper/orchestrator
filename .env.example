# HTTP(S) listen address used by the orchestrator process.
ORCH_LISTEN=:9091

# Local state directory. Contains bbolt DB, generated keys and update artifacts.
ORCH_STATE_DIR=./orch-state

# Unix socket used by the config signer sidecar.
ORCH_SIGNER_SOCKET=./orch-state/signer.sock

# Public URL embedded into bootstrap payloads and used by workers/devices.
ORCH_PUBLIC_URL=https://127.0.0.1:9091

# Optional URL used to probe worker egress metadata.
ORCH_EGRESS_PROBE_URL=http://127.0.0.1:9090/self-describe

# Optional first-run admin password seed. Prefer generated initial password or
# safe CLI input; do not put real secrets in committed files.
ORCH_ADMIN_SECRET=

# Optional update minisign public key. Leave empty to let seed-on-first-run
# generate an update key in ORCH_STATE_DIR and publish its public key.
ORCH_UPDATE_PUBKEY=

# Set to 0 to disable the built-in self-signed TLS listener for local dev only.
ORCH_TLS=1

# Optional seed APK publishing. If this file exists on first start, the
# orchestrator signs and publishes it as APK update seq=1.
SEED_APK_PATH=/seed/app.apk
SEED_APK_VERSION_CODE=1
SEED_APK_VERSION_NAME=seed
